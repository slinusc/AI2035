# Copy to .env for local development. On Heroku, set these as config vars.

# --- Provider ---------------------------------------------------------------
# Which backend to use: "openai" (default) or "anthropic".
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...
# Exact API model id. GPT-5.6 Luna is the intended default — confirm the
# precise id string that the OpenAI API expects.
OPENAI_MODEL=gpt-5.6-luna

# Anthropic (only needed when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# Set true to enable Claude adaptive thinking (higher quality, more latency).
ANTHROPIC_THINKING=false

# Max output tokens per response.
MAX_TOKENS=8192

# --- System prompt (components 1 + 4: Goal + Work assignment) ---------------
# Path to the prompt file (relative to the app root)...
SYSTEM_PROMPT_PATH=prompts/system_prompt.md
# ...or inline text, which overrides the file when set.
# SYSTEM_PROMPT=

# --- Auth (required for persistence) ----------------------------------------
APP_USERNAME=admin
APP_PASSWORD=change-me
# Generate with: chainlit create-secret
CHAINLIT_AUTH_SECRET=

# --- Database (Heroku provides DATABASE_URL automatically) ------------------
DATABASE_URL=postgres://user:pass@localhost:5432/vision2035
# SSL: leave unset to auto-detect (off for localhost, on otherwise),
# or force with DB_SSL=true / DB_SSL=false.
# DB_SSL=
